# Postgres connection used by the product API domains (auth, family, devices, ...).
ISFAM_DATABASE_URL=postgresql+psycopg2://isfam:isfam@127.0.0.1:5433/isfam

# JWT settings. Generate a real secret for anything beyond local development.
ISFAM_JWT_SECRET_KEY=dev-only-change-me
ISFAM_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
ISFAM_JWT_REFRESH_TOKEN_EXPIRE_DAYS=14

# Demo policy: OTP is fixed instead of sending a real SMS.
ISFAM_AUTH_FIXED_VERIFICATION_CODE=123456
